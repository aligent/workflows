{
  "problemMatcher": [
    {
      "owner": "tsc",
      "pattern": [
        {
          "regexp": "(\\S+\\.\\w+)\\((\\d+),(\\d+)\\):\\s+(error|warning)\\s+(TS\\d+:\\s+.+)\\s*$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      ]
    }
  ]
}
