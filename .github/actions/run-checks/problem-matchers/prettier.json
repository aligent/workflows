{
  "problemMatcher": [
    {
      "owner": "prettier-warn",
      "severity": "warning",
      "pattern": [
        {
          "regexp": "\\[warn\\]\\s+(\\S+\\.\\w+)\\s*$",
          "file": 1,
          "message": 1
        }
      ]
    },
    {
      "owner": "prettier-error",
      "severity": "error",
      "pattern": [
        {
          "regexp": "\\[error\\]\\s+(\\S+\\.\\w+)\\s*$",
          "file": 1,
          "message": 1
        }
      ]
    }
  ]
}
